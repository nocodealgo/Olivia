{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "@cloudflare/workers-types"
        ],
        "isolatedModules": true,
        "noEmit": true
    },
    "include": [
        "src/worker/**/*"
    ]
}