# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── LLM ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Security ──────────────────────────────────────────
# Comma-separated Telegram user IDs that may interact with the bot.
# Find yours: message @userinfobot on Telegram — it replies with your numeric ID.
ALLOWED_USER_IDS=123456789

# ── Agent ─────────────────────────────────────────────
# Max tool-call iterations per message (safety limit)
MAX_TOOL_ITERATIONS=10

# ── Memory ────────────────────────────────────────────
# Path to SQLite database (default: ./giorgio.db)
# MEMORY_DB_PATH=./giorgio.db

# ── Voice ─────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── WhatsApp ──────────────────────────────────────────
# Set to true to enable WhatsApp. On first run, scan the QR code in terminal.
# Only messages you send from your own phone are processed (locked to your number).
WHATSAPP_ENABLED=false

# ── Supabase (cloud persistence, optional) ────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Ollama (local LLMs, optional) ─────────────────────
OLLAMA_URL=http://localhost:11434

# ── Brave Search API (optional, 2K free queries/month) ─
# Get key: brave.com/search/api → Free plan
BRAVE_SEARCH_API_KEY=

# ── Google Custom Search (optional, domain-specific) ──
# Restrict this key to "Custom Search API" only in Google Cloud Console
# Get API key: console.cloud.google.com → Enable "Custom Search API"
# Get CX: programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# ── Gmail (optional) ─────────────────────────────────
# Create OAuth2 credentials in Google Cloud Console:
# 1. Enable "Gmail API" in your GCP project
# 2. Create OAuth2 Client ID (type: Web Application)
# 3. Add redirect URI: http://localhost:3100/gmail/callback
# 4. For Pub/Sub real-time notifications:
#    a. Enable "Cloud Pub/Sub API"
#    b. Create topic: projects/{project}/topics/gmail-notifications
#    c. Grant gmail-api-push@system.gserviceaccount.com "Pub/Sub Publisher"
#    d. Create push subscription → https://your-server/gmail/pubsub
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3100/gmail/callback
# GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications
